  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "mobile:dev": "vite --config mobile/vite.config.js --host 0.0.0.0",
    "mobile:build": "vite build --config mobile/vite.config.js",
    "mobile:package-update": "bun run mobile:build && node scripts/package-mobile-update.mjs",
    "cap:sync": "bun run mobile:build && cap sync android",
    "android:open": "cap open android",
    "android:run": "bun run mobile:build && cap run android",
    "android:apk": "bun run mobile:build && cap sync android && cd android && ./gradlew assembleRelease"
